# Backend Settings placeholders (services/api/src/creditops/config.py).
# All customer data, policies, documents, and banking-system responses in this
# project are synthetic and created solely for demonstration.
#
# This file is loaded by pydantic-settings (Settings.model_config.env_file)
# when you run the API or worker locally. It is NOT auto-loaded by
# scripts/smoke_fpt.py or scripts/run_fpt_benchmark.py, which read
# os.environ directly (no load_dotenv anywhere in the codebase) — export
# this file into your shell first if you need those scripts to see it:
#   set -a; source .env; set +a

APP_ENV=development
DATA_CLASS=synthetic
SERVICE_NAME=creditops-api
LOG_LEVEL=INFO

# Which queue this worker process serves. Unset by default: a worker with no
# explicit WORKER_MODE refuses to run (exit 78, fail closed). Cloud Run sets
# this per Job via deploy.yml's --update-env-vars; for local worker runs pick
# one explicitly.
# WORKER_MODE=document
# WORKER_MODE=agent

# Postgres connection string for Supabase (Settings.database_url).
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# RS256 JWT identity-provider configuration for services/api/src/creditops/api/auth.py
# (require_actor). No provider has been chosen yet for this project — see
# docs/DEPLOYMENT_RUNBOOK.md, "Cau hoi con mo de lai trong so tay nay" (Open
# questions). Required (and enforced by Settings.model_post_init) only when
# APP_ENV=production.
# OIDC_ISSUER=https://<issuer>/
# OIDC_AUDIENCE=<audience>
# OIDC_JWKS_URL=https://<issuer>/.well-known/jwks.json

# Supabase project coordinates (Storage + Postgres). SUPABASE_URL and
# SUPABASE_SERVICE_ROLE_KEY are required for services/api/src/creditops/infrastructure/supabase/storage.py.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-never-committed>
# SUPABASE_STORAGE_TUS_URL=https://<project-ref>.supabase.co/storage/v1/upload/resumable
# SUPABASE_STORAGE_MAX_UPLOAD_BYTES=104857600
# SUPABASE_STORAGE_INTENT_TTL_SECONDS=900

# Cloud Run worker Job coordinates for the API's on-demand dispatcher
# (services/api/src/creditops/main.py). All three must be present together or
# dispatch stays disabled and the per-minute Cloud Scheduler sweep is the only
# trigger (fail closed) — see config.py comment above these fields.
# GCP_PROJECT_ID=<gcp-project-id>
# GCP_LOCATION=<gcp-region>
# GCP_WORKER_JOB_NAME=creditops-worker

# FPT AI Factory managed inference (services/api/src/creditops/infrastructure/fpt/catalog.py).
# Read directly from os.environ by the worker/evaluation harness, not by
# Settings — see the note at the top of this file about exporting into your
# shell. Never commit real values. Only set capabilities that have a pinned
# model in model_catalog.py today (reasoning, vision, embedding) — configuring
# an endpoint for kie/table (unpinned) disables the ENTIRE gateway, fail
# closed (creditops/infrastructure/fpt/catalog.py).
# FPT_API_KEY=<fpt-api-key-never-committed>
# FPT_REASONING_ENDPOINT_URL=https://<fpt-endpoint>
# FPT_REASONING_ENDPOINT_ID=<endpoint-id>
# FPT_VISION_ENDPOINT_URL=https://<fpt-endpoint>
# FPT_VISION_ENDPOINT_ID=<endpoint-id>
# FPT_EMBEDDING_ENDPOINT_URL=https://<fpt-endpoint>
# FPT_EMBEDDING_ENDPOINT_ID=<endpoint-id>

# Anonymous synthetic demo session (services/api/src/creditops/api/demo_sessions.py
# and Settings in config.py). When DEMO_SESSION_ENABLED=true AND
# DEMO_JWT_PRIVATE_KEY is present, the API mints its OWN short-TTL RS256 session
# tokens and validates them locally with a public key derived from that private
# key — so an external OIDC provider is NOT required in production (the demo
# issuer replaces OIDC_*). Disabled by default (fail closed): the mint endpoint
# is not even mounted unless both the flag and the key are set. Every artifact
# created by a demo session is SYNTHETIC and labelled as such.
#
# DEMO_JWT_PRIVATE_KEY must be a PEM-encoded RSA private key (>= 2048 bits) and
# is a SECRET: inject it from Secret Manager, never commit a real value. Only
# the DERIVED public key is ever exposed to the API's own verifier; it is never
# returned to a client, embedded in a token, or logged.
#   Generate a throwaway demo key locally:
#     openssl genrsa 2048
# DEMO_SESSION_ENABLED=false
# DEMO_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# DEMO_JWT_ISSUER=https://demo.creditops.local/
# DEMO_JWT_AUDIENCE=creditops-api
# DEMO_JWT_KID=creditops-demo-v1
# DEMO_SESSION_TTL_SECONDS=3600
# DEMO_SESSION_RATE_LIMIT_BURST=5
# DEMO_SESSION_RATE_LIMIT_REFILL_PER_SECOND=0.5
